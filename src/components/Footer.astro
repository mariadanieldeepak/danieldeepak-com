---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-gray-200 mt-20 py-16 bg-white">
  <div class="max-w-[1100px] mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      <!-- Brand -->
      <div>
        <h3 class="text-2xl font-bold text-primary mb-2">Daniel Deepak</h3>
        <p class="text-gray-600">
          Thoughts on business, thinking, and the tools we build.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="font-bold text-primary mb-4">Navigation</h4>
        <ul class="space-y-2 text-gray-600">
          <li>
            <a href="/" class="hover:text-accent transition">Home</a>
          </li>
          <li>
            <a href="/about/" class="hover:text-accent transition">About</a>
          </li>
          <li>
            <a href="/blog/" class="hover:text-accent transition">Blog</a>
          </li>
          <li>
            <a href="/now/" class="hover:text-accent transition">Now</a>
          </li>
          <li>
            <a href="/tools/" class="hover:text-accent transition">Tools</a>
          </li>
        </ul>
      </div>

      <!-- Social -->
      <div>
        <h4 class="font-bold text-primary mb-4">Social</h4>
        <ul class="space-y-2 text-gray-600">
          <li>
            <a
              href="https://twitter.com"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-accent transition"
            >
              Twitter/X
            </a>
          </li>
          <li>
            <a
              href="https://linkedin.com"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-accent transition"
            >
              LinkedIn
            </a>
          </li>
          <li>
            <a
              href="https://github.com"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-accent transition"
            >
              GitHub
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Copyright -->
    <div class="border-t border-gray-200 pt-8 text-center text-gray-600 text-sm">
      <p>&copy; {currentYear} Daniel Deepak. All rights reserved.</p>
    </div>
  </div>
</footer>
