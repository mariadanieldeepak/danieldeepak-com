---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Daniel Deepak. Send me a message for inquiries, collaborations, or just to say hello."
>
  <div class="py-12 md:py-20 max-w-3xl mx-auto">
    <h1 class="text-4xl md:text-5xl font-bold mb-4">Get In Touch</h1>
    <p class="text-lg text-gray-600 mb-12">
      Have a question, collaboration opportunity, or just want to say hello? I'd love to hear from you.
      Fill out the form below and I'll get back to you as soon as I can.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-[2fr_1fr] gap-12">
      <!-- Contact Form -->
      <div>
        <ContactForm />
      </div>

      <!-- Contact Info -->
      <div class="space-y-8">
        <div>
          <h3 class="font-bold text-lg mb-2">Other Ways to Reach Me</h3>
          <p class="text-gray-600 text-sm mb-4">
            Prefer other channels? Connect with me on social media:
          </p>
          <div class="space-y-3">
            <a
              href="https://twitter.com"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-accent hover:underline transition"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path
                  d="M6.29 18.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0020 3.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.073 4.073 0 01.8 7.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 010 16.407a11.616 11.616 0 006.29 1.84"
                ></path>
              </svg>
              Twitter/X
            </a>
            <a
              href="https://linkedin.com"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-accent hover:underline transition"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path
                  d="M16.338 16.338H13.67V12.16c0-.995-.017-2.292-1.194-2.292-1.195 0-1.38.932-1.38 1.893v4.622h-2.67V9.25h2.56v.973h.037c.035-.061.181-.12.404-.12 1.495 0 1.771.742 1.771 1.488v4.082zM5.887 8.856c-.564 0-1.018-.466-1.018-1.04s.454-1.04 1.018-1.04 1.019.465 1.019 1.04-.455 1.04-1.019 1.04zm.844 7.482H4.358V9.25h2.373v7.088zM17.052 0H2.948C1.554 0 .5 1.045.5 2.333v15.334C.5 18.955 1.554 20 2.948 20h14.104c1.394 0 2.448-1.045 2.448-2.333V2.333C19.5 1.045 18.446 0 17.052 0z"
                ></path>
              </svg>
              LinkedIn
            </a>
          </div>
        </div>

        <div class="pt-4 border-t border-gray-200">
          <h3 class="font-bold text-lg mb-2">Response Time</h3>
          <p class="text-gray-600 text-sm">
            I try to respond to messages within 48 hours. Thank you for your patience!
          </p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  a {
    color: #2563eb;
  }
</style>
