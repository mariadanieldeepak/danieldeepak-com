---
import BaseLayout from '../layouts/BaseLayout.astro';

const toolCategories = [
  {
    name: 'Code Editor',
    description: 'Tools for writing and editing code',
    tools: [
      {
        name: 'Neovim',
        description: 'A hyperextensible Vim-based text editor',
        link: 'https://neovim.io/',
      },
      {
        name: 'Telescope',
        description: 'Fuzzy finder and command palette for Neovim',
        link: 'https://github.com/nvim-telescope/telescope.nvim',
      },
      {
        name: 'VS Code',
        description: 'When I need a GUI, VS Code is still excellent',
        link: 'https://code.visualstudio.com/',
      },
    ],
  },
  {
    name: 'Note Taking & Knowledge',
    description: 'Systems for capturing and organizing information',
    tools: [
      {
        name: 'Obsidian',
        description: 'Local-first, markdown-based personal knowledge base',
        link: 'https://obsidian.md/',
      },
      {
        name: 'Bear',
        description: 'Beautiful, simple note-taking on macOS',
        link: 'https://bear.app/',
      },
    ],
  },
  {
    name: 'Writing',
    description: 'Tools for long-form and focused writing',
    tools: [
      {
        name: 'iA Writer',
        description: 'Distraction-free writing with excellent typography',
        link: 'https://ia.net/writer',
      },
      {
        name: 'Markdown',
        description: 'Plain text format for writing and blogging',
        link: 'https://www.markdownguide.org/',
      },
    ],
  },
  {
    name: 'Productivity & Task Management',
    description: 'Systems for organizing work and priorities',
    tools: [
      {
        name: 'Plain Text .md Files',
        description: 'Simple, intentional task management with checkboxes',
        link: '#',
      },
      {
        name: 'Notion',
        description: 'All-in-one workspace (when I need templates)',
        link: 'https://www.notion.so/',
      },
      {
        name: 'Linear',
        description: 'Issue tracking built for speed and simplicity',
        link: 'https://linear.app/',
      },
    ],
  },
  {
    name: 'Design & Prototyping',
    description: 'Visual design and interface tools',
    tools: [
      {
        name: 'Figma',
        description: 'Collaborative design and prototyping',
        link: 'https://www.figma.com/',
      },
      {
        name: 'Tailwind CSS',
        description: 'Utility-first CSS framework for rapid UI development',
        link: 'https://tailwindcss.com/',
      },
    ],
  },
  {
    name: 'Developer Tools',
    description: 'Command-line and development utilities',
    tools: [
      {
        name: 'Git',
        description: 'Version control and collaboration',
        link: 'https://git-scm.com/',
      },
      {
        name: 'Astro',
        description: 'Modern static site builder with islands architecture',
        link: 'https://astro.build/',
      },
      {
        name: 'Tmux',
        description: 'Terminal multiplexer for efficient workflow',
        link: 'https://github.com/tmux/tmux',
      },
      {
        name: 'Zsh',
        description: 'Unix shell with excellent customization',
        link: 'https://www.zsh.org/',
      },
    ],
  },
  {
    name: 'Terminal & CLI',
    description: 'Command-line tools for productivity',
    tools: [
      {
        name: 'Homebrew',
        description: 'Package manager for macOS',
        link: 'https://brew.sh/',
      },
      {
        name: 'fzf',
        description: 'Command-line fuzzy finder',
        link: 'https://github.com/junegunn/fzf',
      },
      {
        name: 'ripgrep',
        description: 'Fast line-oriented search tool',
        link: 'https://github.com/BurntSushi/ripgrep',
      },
    ],
  },
  {
    name: 'Communication',
    description: 'Tools for staying connected and collaborating',
    tools: [
      {
        name: 'Email',
        description: 'Still one of the best tools for asynchronous communication',
        link: '#',
      },
      {
        name: 'Twitter/X',
        description: 'Where I share thoughts and engage with the community',
        link: 'https://twitter.com/',
      },
      {
        name: 'LinkedIn',
        description: 'Professional network and thought leadership platform',
        link: 'https://linkedin.com/',
      },
    ],
  },
];
---

<BaseLayout title="Tools" description="The tools and software I use regularly.">
  <div class="py-12 md:py-20">
    <h1 class="text-4xl md:text-5xl font-bold mb-4">Tools</h1>
    <p class="text-lg text-gray-600 mb-12">
      A curated list of tools that I use regularly and that have genuinely improved my
      workflow. I've tried many tools; these are the ones that have stuck around.
    </p>

    <div class="space-y-16">
      {
        toolCategories.map((category) => (
          <section>
            <div class="mb-8">
              <h2 class="text-2xl font-bold text-primary mb-2">{category.name}</h2>
              <p class="text-gray-600">{category.description}</p>
            </div>

            <div class="space-y-4">
              {category.tools.map((tool) => (
                <div class="border-l-4 border-accent pl-6 py-2">
                  <h3 class="font-bold text-lg mb-1">
                    {tool.link !== '#' ? (
                      <a
                        href={tool.link}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-accent hover:opacity-80 transition"
                      >
                        {tool.name} ↗
                      </a>
                    ) : (
                      tool.name
                    )}
                  </h3>
                  <p class="text-gray-600">{tool.description}</p>
                </div>
              ))}
            </div>
          </section>
        ))
      }
    </div>

    <div class="mt-16 pt-8 border-t border-gray-200">
      <p class="text-gray-600">
        This list is a snapshot of my current workflow. Like any good tool selection, it
        evolves as my needs change and new solutions emerge. I'm always experimenting with
        new tools—if you have recommendations, let me know!
      </p>
    </div>
  </div>
</BaseLayout>
