---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import BlogCard from '../components/BlogCard.astro';

const allPosts = await getCollection('blog');
const recentPosts = allPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 6);
---

<BaseLayout title="Home" description="Thoughts on business, thinking, and building.">
  <Hero />

  <section class="py-16 md:py-24">
    <h2 class="text-3xl md:text-4xl font-bold mb-12">Recent Posts</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {recentPosts.map((post) => <BlogCard post={post} />)}
    </div>
    <div class="text-center mt-12">
      <a
        href="/blog/"
        class="inline-block text-accent font-bold hover:opacity-80 transition text-lg"
      >
        View all posts →
      </a>
    </div>
  </section>
</BaseLayout>
